CODEX_ASR_DOMAIN=asr.example.com
# Use a container-readable copy, for example:
# sudo install -o 10001 -g 65534 -m 0400 ~/.codex/auth.json /opt/codex-asr/auth.json
CODEX_ASR_AUTH_FILE=/opt/codex-asr/auth.json
CODEX_ASR_SERVER_KEY=replace-with-a-long-random-api-key
CODEX_ASR_CONCURRENCY=16
# CODEX_ASR_PROXY=http://host.docker.internal:7890
# Docker images include rust-silk at this path by default.
# CODEX_ASR_SILK_DECODER=/usr/local/bin/rust-silk
